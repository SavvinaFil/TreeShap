{
  "analysis": "tabular",
  "package": "sklearn",
  "model_type": "random_forest",
  "model_path": "source/models/multioutput_classify.pkl",
  "dataset_path": "source/data/multioutput_classify.csv",
  "output_dir": "output/",

  "dataset_scope": "whole",

  "save_excel": true,
  "generate_notebook": true,

  "feature_names": [
    "Wind Speed",
    "Solar Irradiance",
    "Previous Generation",
    "Previous Load",
    "Day Ahead Price",
    "Hour"
