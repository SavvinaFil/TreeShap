      "0": "OFF",
      "1": "ON"
    },
    "1": {
      "0": "OFF",
      "1": "ON"
    },
    "2": {
      "0": "OFF",
      "1": "ON"
    },
    "3": {
      "0": "OFF",
      "1": "ON"
    },
    "4": {
      "0": "OFF",
      "1": "ON"
    },
    "5": {
      "0": "OFF",
      "1": "ON"
    },
    "0_name": "Generator 1",
    "1_name": "Generator 2",
    "2_name": "Generator 3",
    "3_name": "Generator 4",
    "4_name": "Generator 5",
    "5_name": "Generator 6"
  }
